# Public site URL (used for SEO canonical URLs, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://www.navahathayoga.com

# Sanity project configuration
# Find these in your Sanity project settings (https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Optional: server-only token for authenticated/draft reads (do not expose publicly)
SANITY_API_READ_TOKEN=

# Optional: contact form notification email (delivery wiring is a TODO)
CONTACT_NOTIFICATION_EMAIL=
