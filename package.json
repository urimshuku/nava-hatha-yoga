{
  "name": "nava-hatha-yoga",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/clear-dev-lock.mjs",
    "dev": "for n in 524288 262144 131072 65536 32768 24576 12288 10240; do ulimit -n $n 2>/dev/null && break; done; next dev --webpack",
    "dev:turbo": "for n in 524288 262144 131072 65536 32768 24576 12288 10240; do ulimit -n $n 2>/dev/null && break; done; next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "seed:generate": "node scripts/generate-seed.mjs",
    "seed": "node scripts/generate-seed.mjs && sanity dataset import seed/seed.ndjson production --replace",
    "studio:deploy": "sanity deploy"
  },
  "dependencies": {
    "@portabletext/react": "^6.2.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^6.0.0",
    "framer-motion": "^12.40.0",
    "html-to-image": "^1.11.13",
    "next": "^16.2.9",
    "next-sanity": "^13.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanity": "^6.0.0",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  }
}
